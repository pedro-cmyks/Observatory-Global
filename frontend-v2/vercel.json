{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://atlas-api-pedro.fly.dev/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://atlas-api-pedro.fly.dev/health"
    },
    {
      "source": "/((?!api|health).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), magnetometer=(), gyroscope=(), accelerometer=()" }
      ]
    }
  ]
}
