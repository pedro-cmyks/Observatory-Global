# ObservatorioGlobal Backend — Environment Variables
# Copy to .env for local dev. Never commit .env with real values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://observatory:changeme@localhost:5432/observatory?sslmode=disable

# ── News API Keys ─────────────────────────────────────────────────────────────
# NewsData.io — multilingual, 60+ languages. Free: 200 req/day
# https://newsdata.io/dashboard
NEWSDATA_API_KEY=

# MediaStack — Spanish/Portuguese LatAm supplement. Free: 500 req/month
# https://mediastack.com/dashboard
MEDIASTACK_API_KEY=

# NewsAPI.org — targeted crisis queries. Developer: 100 req/day
# https://newsapi.org
NEWSAPI_KEY=

# ── Optional Connectors ───────────────────────────────────────────────────────
# ACLED — conflict event data. System works without these (returns empty layer).
# Request access at https://acleddata.com/register
ACLED_API_KEY=
ACLED_EMAIL=

# ── Ingestion Tuning ──────────────────────────────────────────────────────────
# GDELT cycle interval in seconds (default: 900 = 15 min)
INGEST_INTERVAL_SECONDS=900

# ── Redis (optional caching) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
